#!/bin/sh

# PROVIDE: lxmd
# REQUIRE: rnsd
# KEYWORD: shutdown

. /etc/rc.subr

name="lxmd"
rcvar="lxmd_enable"

load_rc_config $name

: ${lxmd_enable:="NO"}
: ${lxmd_user:="reticulum"}
: ${lxmd_config:="/usr/local/etc/lxmf"}
: ${lxmd_rnsconfig:="/usr/local/etc/reticulum"}
: ${lxmd_propagation:="YES"}
: ${lxmd_log:="/var/log/reticulum/lxmd.log"}

pidfile="/var/run/${name}.pid"
command="/usr/local/reticulum-venv/bin/lxmd"

# Build command args
lxmd_flags=""
if checkyesno lxmd_propagation; then
    lxmd_flags="-p"
fi
command_args="--service ${lxmd_flags} --config ${lxmd_config} --rnsconfig ${lxmd_rnsconfig}"

start_precmd="${name}_prestart"
start_cmd="${name}_start"
stop_cmd="${name}_stop"
stop_postcmd="${name}_poststop"

lxmd_prestart()
{
    # Check that rnsd is running
    if ! pgrep -qF /var/run/rnsd.pid 2>/dev/null; then
        echo "rnsd is not running. lxmd requires rnsd to be started first."
        return 1
    fi

    # Ensure config directory exists with restrictive permissions (identity keys inside)
    if [ ! -d "${lxmd_config}" ]; then
        mkdir -p "${lxmd_config}"
    fi
    chown ${lxmd_user}:${lxmd_user} "${lxmd_config}"
    chmod 700 "${lxmd_config}"

    # Ensure identity key files created by lxmd are not world-readable
    umask 077
}

lxmd_start()
{
    echo "Starting ${name}."
    /usr/sbin/daemon \
        -P "${pidfile}" \
        -u "${lxmd_user}" \
        -o "${lxmd_log}" \
        ${command} ${command_args}
    sleep 2
    if pgrep -qF "${pidfile}" 2>/dev/null; then
        echo "${name} started."
    else
        echo "WARNING: failed to start ${name} — check ${lxmd_log}"
        return 1
    fi
}

lxmd_stop()
{
    if [ -f "${pidfile}" ]; then
        kill $(cat "${pidfile}") 2>/dev/null || true
    fi
}

lxmd_poststop()
{
    rm -f ${pidfile}
}

run_rc_command "$1"
