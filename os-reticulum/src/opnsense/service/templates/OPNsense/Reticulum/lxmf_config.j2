{# LXMF Configuration - Generated by OPNsense #}
{# Do not edit manually — changes will be overwritten on next reconfigure #}
{% set lxmf = OPNsense.Reticulum.lxmf %}
{% macro yesno(val) %}{% if val|default('0') == '1' %}yes{% else %}no{% endif %}{% endmacro %}

[lxmf]
  display_name = {{ lxmf.display_name|default('Anonymous Peer')|replace('\n', '')|replace('\r', '')|replace('[', '') }}
  announce_at_start = {{ yesno(lxmf.lxmf_announce_at_start) }}
{% if lxmf.lxmf_announce_interval|default('') != '' %}
  announce_interval = {{ lxmf.lxmf_announce_interval }}
{% endif %}
  delivery_transfer_max_accepted_size = {{ lxmf.delivery_transfer_max_size|default('1000') }}
{% if lxmf.on_inbound|default('') != '' %}
  on_inbound = {{ lxmf.on_inbound|replace('\n', '')|replace('\r', '')|replace('[', '') }}
{% endif %}

[propagation]
  enable_node = {{ yesno(lxmf.enable_node) }}
{% if lxmf.enable_node|default('0') == '1' %}
{% if lxmf.node_name|default('') != '' %}
  node_name = {{ lxmf.node_name|replace('\n', '')|replace('\r', '')|replace('[', '') }}
{% endif %}
  announce_interval = {{ lxmf.announce_interval|default('360') }}
  announce_at_start = {{ yesno(lxmf.announce_at_start) }}
  message_storage_limit = {{ lxmf.message_storage_limit|default('500') }}
  propagation_message_max_accepted_size = {{ lxmf.propagation_message_max_size|default('256') }}
  propagation_sync_max_accepted_size = {{ lxmf.propagation_sync_max_size|default('10240') }}
  propagation_stamp_cost_target = {{ lxmf.stamp_cost_target|default('16') }}
  propagation_stamp_cost_flexibility = {{ lxmf.stamp_cost_flexibility|default('3') }}
  peering_cost = {{ lxmf.peering_cost|default('18') }}
  remote_peering_cost_max = {{ lxmf.remote_peering_cost_max|default('26') }}
  max_peers = {{ lxmf.max_peers|default('20') }}
  autopeer = {{ yesno(lxmf.autopeer) }}
  autopeer_maxdepth = {{ lxmf.autopeer_maxdepth|default('6') }}
  from_static_only = {{ yesno(lxmf.from_static_only) }}
  auth_required = {{ yesno(lxmf.auth_required) }}
{% if lxmf.static_peers|default('') != '' %}
  static_peers = {{ lxmf.static_peers }}
{% endif %}
{% if lxmf.control_allowed|default('') != '' %}
  control_allowed = {{ lxmf.control_allowed }}
{% endif %}
{% if lxmf.prioritise_destinations|default('') != '' %}
  prioritise_destinations = {{ lxmf.prioritise_destinations }}
{% endif %}
{% endif %}

[logging]
  loglevel = {{ lxmf.loglevel|default('4') }}
{% if lxmf.logfile|default('') != '' %}
  logfile = {{ lxmf.logfile|replace('\n', '')|replace('\r', '')|replace('[', '') }}
{% endif %}
