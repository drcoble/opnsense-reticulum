{# Reticulum Network Stack Configuration - Generated by OPNsense #}
{# Do not edit manually — changes will be overwritten on next reconfigure #}
{% set general = OPNsense.Reticulum.general %}
{% macro bool(val) %}{% if val|default('0') == '1' %}True{% else %}False{% endif %}{% endmacro %}

[reticulum]
  enable_transport = {{ bool(general.enable_transport) }}
  share_instance = {{ bool(general.share_instance) }}
{% if general.share_instance|default('1') == '1' %}
  shared_instance_port = {{ general.shared_instance_port|default('37428') }}
  instance_control_port = {{ general.instance_control_port|default('37429') }}
{% endif %}
  panic_on_interface_error = {{ bool(general.panic_on_interface_error) }}
{% if general.respond_to_probes|default('0') == '1' %}
  respond_to_probes = True
{% endif %}
{% if general.enable_remote_management|default('0') == '1' %}
  enable_remote_management = True
{% if general.remote_management_allowed|default('') != '' %}
  remote_management_allowed = {{ general.remote_management_allowed }}
{% endif %}
{% endif %}
{% if general.rpc_key is defined and general.rpc_key|default('') != '' %}
  rpc_key = {{ general.rpc_key }}
{% endif %}

[logging]
  loglevel = {{ general.loglevel|default('4') }}
{% if general.logfile|default('') != '' %}
  logfile = {{ general.logfile|replace('\n', '')|replace('\r', '')|replace('[', '') }}
{% endif %}

{% if OPNsense.Reticulum.interfaces is defined and OPNsense.Reticulum.interfaces.interface is defined %}
{% for iface in OPNsense.Reticulum.interfaces.interface %}
{% if iface.enabled|default('1') == '1' %}

[[{{ iface.name|replace('\n', '')|replace('\r', '')|replace('[', '')|replace(']', '') }}]]
  type = {{ iface.type }}
{% if iface.mode|default('full') != 'full' %}
  mode = {{ iface.mode }}
{% endif %}
{% if iface.outgoing|default('1') == '0' %}
  outgoing = False
{% endif %}
{% if iface.network_name|default('') != '' %}
  network_name = {{ iface.network_name|replace('\n', '')|replace('\r', '')|replace('[', '') }}
{% endif %}
{% if iface.passphrase|default('') != '' %}
  passphrase = {{ iface.passphrase|replace('\n', '')|replace('\r', '') }}
{% endif %}
{% if iface.ifac_size|default('') != '' %}
  ifac_size = {{ iface.ifac_size }}
{% endif %}
{% if iface.announce_cap|default('') != '' %}
  announce_cap = {{ iface.announce_cap }}
{% endif %}
{% if iface.bitrate|default('') != '' %}
  bitrate = {{ iface.bitrate }}
{% endif %}
{% if iface.bootstrap_only|default('0') == '1' %}
  bootstrap_only = True
{% endif %}

{# === TCPServerInterface === #}
{% if iface.type == 'TCPServerInterface' or iface.type == 'BackboneInterface' %}
  listen_ip = {{ iface.listen_ip|default('0.0.0.0') }}
  listen_port = {{ iface.listen_port|default('4242') }}
{% if iface.prefer_ipv6|default('0') == '1' %}
  prefer_ipv6 = True
{% endif %}
{% if iface.device|default('') != '' %}
  device = {{ iface.device }}
{% endif %}
{% if iface.i2p_tunneled|default('0') == '1' %}
  i2p_tunneled = True
{% endif %}

{# === TCPClientInterface === #}
{% elif iface.type == 'TCPClientInterface' %}
  target_host = {{ iface.target_host }}
  target_port = {{ iface.target_port|default('4242') }}
{% if iface.prefer_ipv6|default('0') == '1' %}
  prefer_ipv6 = True
{% endif %}
{% if iface.kiss_framing|default('0') == '1' %}
  kiss_framing = True
{% endif %}
{% if iface.fixed_mtu|default('') != '' %}
  fixed_mtu = {{ iface.fixed_mtu }}
{% endif %}
{% if iface.i2p_tunneled|default('0') == '1' %}
  i2p_tunneled = True
{% endif %}

{# === UDPInterface === #}
{% elif iface.type == 'UDPInterface' %}
  listen_ip = {{ iface.listen_ip|default('0.0.0.0') }}
  listen_port = {{ iface.listen_port|default('4242') }}
  forward_ip = {{ iface.forward_ip }}
  forward_port = {{ iface.forward_port|default('4242') }}
{% if iface.prefer_ipv6|default('0') == '1' %}
  prefer_ipv6 = True
{% endif %}
{% if iface.device|default('') != '' %}
  device = {{ iface.device }}
{% endif %}

{# === AutoInterface === #}
{% elif iface.type == 'AutoInterface' %}
{% if iface.group_id|default('') != '' %}
  group_id = {{ iface.group_id }}
{% endif %}
{% if iface.multicast_address_type|default('temporary') != 'temporary' %}
  multicast_address_type = {{ iface.multicast_address_type }}
{% endif %}
{% if iface.devices|default('') != '' %}
  devices = {{ iface.devices }}
{% endif %}
{% if iface.ignored_devices|default('') != '' %}
  ignored_devices = {{ iface.ignored_devices }}
{% endif %}
{% if iface.discovery_scope|default('link') != 'link' %}
  discovery_scope = {{ iface.discovery_scope }}
{% endif %}
{% if iface.discovery_port|default('29716') != '29716' %}
  discovery_port = {{ iface.discovery_port }}
{% endif %}
{% if iface.data_port|default('42671') != '42671' %}
  data_port = {{ iface.data_port }}
{% endif %}

{# === RNodeInterface === #}
{% elif iface.type == 'RNodeInterface' %}
  port = {{ iface.port }}
  frequency = {{ iface.frequency }}
  bandwidth = {{ iface.bandwidth }}
  txpower = {{ iface.txpower }}
  spreadingfactor = {{ iface.spreadingfactor }}
  codingrate = {{ iface.codingrate }}
{% if iface.flow_control|default('0') == '1' %}
  flow_control = True
{% endif %}
{% if iface.airtime_limit_long|default('') != '' %}
  airtime_limit_long = {{ iface.airtime_limit_long }}
{% endif %}
{% if iface.airtime_limit_short|default('') != '' %}
  airtime_limit_short = {{ iface.airtime_limit_short }}
{% endif %}
{% if iface.speed|default('') != '' %}
  speed = {{ iface.speed }}
{% endif %}
{% if iface.id_callsign|default('') != '' %}
  id_callsign = {{ iface.id_callsign }}
{% endif %}
{% if iface.id_interval|default('') != '' %}
  id_interval = {{ iface.id_interval }}
{% endif %}

{# === RNodeMultiInterface === #}
{# SECURITY NOTE (X-710): sub_interfaces_raw is emitted verbatim below.
   An admin with write access can inject arbitrary INI content including duplicate
   [reticulum] sections. The legitimate [reticulum] section is rendered first (top
   of this file), so rnsd reads it first. Python ConfigObj merges duplicate sections
   with later values winning for any duplicate keys — mitigated by the legitimate
   section appearing first. This is an accepted architectural trade-off: OPNsense
   ArrayField cannot represent nested sub-interfaces. Mitigations: (1) only admins
   with the reticulum ACL privilege can set this field; (2) the GUI displays a
   prominent security warning on the sub_interfaces_raw textarea. #}
{% elif iface.type == 'RNodeMultiInterface' %}
  port = {{ iface.port }}
{% if iface.sub_interfaces_raw|default('') != '' %}
{{ iface.sub_interfaces_raw }}
{% endif %}

{# === SerialInterface === #}
{% elif iface.type == 'SerialInterface' %}
  port = {{ iface.port }}
  speed = {{ iface.speed|default('9600') }}
  databits = {{ iface.databits|default('8') }}
  parity = {{ iface.parity|default('none') }}
  stopbits = {{ iface.stopbits|default('1') }}
{% if iface.flow_control|default('0') == '1' %}
  flow_control = True
{% endif %}

{# === KISSInterface === #}
{% elif iface.type == 'KISSInterface' %}
  port = {{ iface.port }}
  speed = {{ iface.speed|default('9600') }}
  parity = {{ iface.parity|default('none') }}
  stopbits = {{ iface.stopbits|default('1') }}
{% if iface.flow_control|default('0') == '1' %}
  flow_control = True
{% endif %}
{% if iface.preamble|default('') != '' %}
  preamble = {{ iface.preamble }}
{% endif %}
{% if iface.txtail|default('') != '' %}
  txtail = {{ iface.txtail }}
{% endif %}
{% if iface.persistence|default('') != '' %}
  persistence = {{ iface.persistence }}
{% endif %}
{% if iface.slottime|default('') != '' %}
  slottime = {{ iface.slottime }}
{% endif %}
{% if iface.id_callsign|default('') != '' %}
  id_callsign = {{ iface.id_callsign }}
{% endif %}
{% if iface.id_interval|default('') != '' %}
  id_interval = {{ iface.id_interval }}
{% endif %}

{# === AX25KISSInterface === #}
{% elif iface.type == 'AX25KISSInterface' %}
  port = {{ iface.port }}
  speed = {{ iface.speed|default('9600') }}
  parity = {{ iface.parity|default('none') }}
  stopbits = {{ iface.stopbits|default('1') }}
{% if iface.flow_control|default('0') == '1' %}
  flow_control = True
{% endif %}
  callsign = {{ iface.callsign }}
  ssid = {{ iface.ssid|default('0') }}
{% if iface.preamble|default('') != '' %}
  preamble = {{ iface.preamble }}
{% endif %}
{% if iface.txtail|default('') != '' %}
  txtail = {{ iface.txtail }}
{% endif %}
{% if iface.persistence|default('') != '' %}
  persistence = {{ iface.persistence }}
{% endif %}
{% if iface.slottime|default('') != '' %}
  slottime = {{ iface.slottime }}
{% endif %}
{% if iface.id_callsign|default('') != '' %}
  id_callsign = {{ iface.id_callsign }}
{% endif %}
{% if iface.id_interval|default('') != '' %}
  id_interval = {{ iface.id_interval }}
{% endif %}

{# === PipeInterface === #}
{% elif iface.type == 'PipeInterface' %}
  command = {{ iface.command|replace('\n', '')|replace('\r', '')|replace('[', '') }}
{% if iface.respawn_delay|default('5') != '5' %}
  respawn_delay = {{ iface.respawn_delay }}
{% endif %}

{# === I2PInterface === #}
{% elif iface.type == 'I2PInterface' %}
{% if iface.connectable|default('0') == '1' %}
  connectable = True
{% endif %}
{% if iface.i2p_peers|default('') != '' %}
  peers = {{ iface.i2p_peers }}
{% endif %}
{% if iface.target_host|default('') != '' %}
  sam_host = {{ iface.target_host|replace('\n', '')|replace('\r', '') }}
{% endif %}
{% if iface.target_port|default('') != '' %}
  sam_port = {{ iface.target_port }}
{% endif %}

{% endif %}

{# === Discoverable settings (TCPServer/Backbone) === #}
{% if iface.type in ['TCPServerInterface', 'BackboneInterface'] %}
{% if iface.discoverable|default('0') == '1' %}
  discoverable = True
{% if iface.discovery_name|default('') != '' %}
  discovery_name = {{ iface.discovery_name|replace('\n', '')|replace('\r', '')|replace('[', '') }}
{% endif %}
{% if iface.announce_interval|default('') != '' %}
  announce_interval = {{ iface.announce_interval }}
{% endif %}
{% if iface.reachable_on|default('') != '' %}
  reachable_on = {{ iface.reachable_on|replace('\n', '')|replace('\r', '')|replace('[', '') }}
{% endif %}
{% if iface.latitude|default('') != '' %}
  latitude = {{ iface.latitude }}
{% endif %}
{% if iface.longitude|default('') != '' %}
  longitude = {{ iface.longitude }}
{% endif %}
{% if iface.height|default('') != '' %}
  height = {{ iface.height }}
{% endif %}
{% if iface.discovery_stamp_value|default('') != '' %}
  discovery_stamp_value = {{ iface.discovery_stamp_value }}
{% endif %}
{% if iface.discovery_encrypt|default('0') == '1' %}
  discovery_encrypt = True
{% endif %}
{% if iface.publish_ifac|default('0') == '1' %}
  publish_ifac = True
{% endif %}
{% endif %}
{% endif %}

{# === Announce rate control (all types) === #}
{% if iface.announce_rate_target|default('') != '' %}
  announce_rate_target = {{ iface.announce_rate_target }}
{% if iface.announce_rate_grace|default('') != '' %}
  announce_rate_grace = {{ iface.announce_rate_grace }}
{% endif %}
{% if iface.announce_rate_penalty|default('') != '' %}
  announce_rate_penalty = {{ iface.announce_rate_penalty }}
{% endif %}
{% endif %}

{# === Ingress control === #}
{% if iface.ingress_control|default('0') == '1' %}
  ingress_control = True
{% if iface.ic_new_time|default('') != '' %}
  ic_new_time = {{ iface.ic_new_time }}
{% endif %}
{% if iface.ic_burst_freq_new|default('') != '' %}
  ic_burst_freq_new = {{ iface.ic_burst_freq_new }}
{% endif %}
{% if iface.ic_burst_freq|default('') != '' %}
  ic_burst_freq = {{ iface.ic_burst_freq }}
{% endif %}
{% if iface.ic_max_held_announces|default('') != '' %}
  ic_max_held_announces = {{ iface.ic_max_held_announces }}
{% endif %}
{% if iface.ic_burst_hold|default('') != '' %}
  ic_burst_hold = {{ iface.ic_burst_hold }}
{% endif %}
{% if iface.ic_burst_penalty|default('') != '' %}
  ic_burst_penalty = {{ iface.ic_burst_penalty }}
{% endif %}
{% if iface.ic_held_release_interval|default('') != '' %}
  ic_held_release_interval = {{ iface.ic_held_release_interval }}
{% endif %}
{% endif %}

{% endif %}
{% endfor %}
{% endif %}
